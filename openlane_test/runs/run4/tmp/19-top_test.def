    - addr[5] ( PIN addr[5] ) ( u_sram addr[5] ) + USE SIGNAL ;
    - clk ( PIN clk ) ( u_sram clk ) + USE CLOCK ;
    - cs ( PIN cs ) ( u_sram cs ) + USE SIGNAL ;
    - din[0] ( PIN din[0] ) ( u_sram din[0] ) + USE SIGNAL ;
    - din[1] ( PIN din[1] ) ( u_sram din[1] ) + USE SIGNAL ;
    - din[2] ( PIN din[2] ) ( u_sram din[2] ) + USE SIGNAL ;
    - din[3] ( PIN din[3] ) ( u_sram din[3] ) + USE SIGNAL ;
    - din[4] ( PIN din[4] ) ( u_sram din[4] ) + USE SIGNAL ;
    - din[5] ( PIN din[5] ) ( u_sram din[5] ) + USE SIGNAL ;
    - din[6] ( PIN din[6] ) ( u_sram din[6] ) + USE SIGNAL ;
    - din[7] ( PIN din[7] ) ( u_sram din[7] ) + USE SIGNAL ;
    - dout[0] ( PIN dout[0] ) ( output1 X ) + USE SIGNAL ;
    - dout[1] ( PIN dout[1] ) ( output2 X ) + USE SIGNAL ;
    - dout[2] ( PIN dout[2] ) ( output3 X ) + USE SIGNAL ;
    - dout[3] ( PIN dout[3] ) ( output4 X ) + USE SIGNAL ;
    - dout[4] ( PIN dout[4] ) ( output5 X ) + USE SIGNAL ;
    - dout[5] ( PIN dout[5] ) ( output6 X ) + USE SIGNAL ;
    - dout[6] ( PIN dout[6] ) ( output7 X ) + USE SIGNAL ;
    - dout[7] ( PIN dout[7] ) ( output8 X ) + USE SIGNAL ;
    - net1 ( output1 A ) ( u_sram dout[0] ) + USE SIGNAL ;
    - net2 ( output2 A ) ( u_sram dout[1] ) + USE SIGNAL ;
    - net3 ( output3 A ) ( u_sram dout[2] ) + USE SIGNAL ;
    - net4 ( output4 A ) ( u_sram dout[3] ) + USE SIGNAL ;
    - net5 ( output5 A ) ( u_sram dout[4] ) + USE SIGNAL ;
    - net6 ( output6 A ) ( u_sram dout[5] ) + USE SIGNAL ;
    - net7 ( output7 A ) ( u_sram dout[6] ) + USE SIGNAL ;
    - net8 ( output8 A ) ( u_sram dout[7] ) + USE SIGNAL ;
    - rst_n ( PIN rst_n ) + USE SIGNAL ;
    - we ( PIN we ) ( u_sram we ) + USE SIGNAL ;
END NETS
