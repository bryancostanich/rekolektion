digraph "top_test" {
label="top_test";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="dout", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="din", color="black", fontcolor="black" ];
n3 [ shape=octagon, label="addr", color="black", fontcolor="black" ];
n4 [ shape=octagon, label="cs", color="black", fontcolor="black" ];
n5 [ shape=octagon, label="we", color="black", fontcolor="black" ];
n6 [ shape=octagon, label="rst_n", color="black", fontcolor="black" ];
n7 [ shape=octagon, label="clk", color="black", fontcolor="black" ];
c8 [ shape=record, label="{{<p3> addr|<p7> clk|<p4> cs|<p2> din|<p5> we}|u_sram\ntest_sram|{<p1> dout}}",  ];
c8:p1:e -> n1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n2:e -> c8:p2:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n3:e -> c8:p3:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n4:e -> c8:p4:w [color="black", fontcolor="black", label=""];
n5:e -> c8:p5:w [color="black", fontcolor="black", label=""];
n7:e -> c8:p7:w [color="black", fontcolor="black", label=""];
}
