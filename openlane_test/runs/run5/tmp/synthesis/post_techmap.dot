digraph "top_test" {
label="top_test";
rankdir="LR";
remincross=true;
n1 [ shape=octagon, label="addr", color="black", fontcolor="black" ];
n2 [ shape=octagon, label="clk", color="black", fontcolor="black" ];
n3 [ shape=octagon, label="cs", color="black", fontcolor="black" ];
n4 [ shape=octagon, label="din", color="black", fontcolor="black" ];
n5 [ shape=octagon, label="dout", color="black", fontcolor="black" ];
n6 [ shape=octagon, label="rst_n", color="black", fontcolor="black" ];
n7 [ shape=octagon, label="we", color="black", fontcolor="black" ];
c8 [ shape=record, label="{{<p1> addr|<p2> clk|<p3> cs|<p4> din|<p7> we}|u_sram\ntest_sram|{<p5> dout}}",  ];
n1:e -> c8:p1:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n2:e -> c8:p2:w [color="black", fontcolor="black", label=""];
n3:e -> c8:p3:w [color="black", fontcolor="black", label=""];
n4:e -> c8:p4:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
c8:p5:e -> n5:w [color="black", fontcolor="black", style="setlinewidth(3)", label=""];
n7:e -> c8:p7:w [color="black", fontcolor="black", label=""];
}
